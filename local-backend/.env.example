APP_ENV=production
APP_PUBLIC_NAME=GapKassa
LEGAL_ENTITY_NAME=GapKassa
PUBLIC_SUPPORT_EMAIL=support@example.com
PRIVACY_EFFECTIVE_DATE=2026-04-16
JWT_SECRET=replace-with-long-random-secret
JWT_ISSUER=gapkassa-prod
GOOGLE_WEB_CLIENT_ID=replace-with-web-client-id.apps.googleusercontent.com
GOOGLE_AUTH_ALLOW_MOCK=false
OTP_PEPPER=replace-with-long-random-secret
PASSWORD_PEPPER=replace-with-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
OTP_TTL_MIN=10
OTP_COOLDOWN_SEC=30
OTP_MAX_ATTEMPTS=5
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MIN=15
MAX_DAILY_OTP_REQUESTS=300
MAX_TEXT_LENGTH=30
MAX_DESCRIPTION_LENGTH=200
PASSWORD_MIN_LEN=8
PASSWORD_MAX_LEN=30
MIN_MEMBERS_PER_ROOM=5
MAX_MEMBERS_PER_ROOM=20
DB_SOFT_LIMIT_MB=256
OUTBOX_SOFT_LIMIT_MB=64
AUDIT_RETENTION_DAYS=180

# For a single VM deployment with persistent disk.
DB_PATH=/data/app.db

# Replace with the public frontend/app origin if needed.
CORS_ORIGINS=https://your-app-domain.example

# Legacy SMTP for OTP emails
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=gapkassa@yandex.com
SMTP_PASS=replace-with-app-password
SMTP_FROM=GapKassa <gapkassa@yandex.com>
SMTP_TLS=false
OTP_ADMIN_EMAIL=gapkassa@yandex.com
CLIENT_ERROR_REPORT_EMAILS=talgat19940914@gmail.com
CLIENT_ERROR_STACKTRACE_MAX_LEN=12000
