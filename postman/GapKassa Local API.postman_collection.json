              "mode": "raw",
              "raw": "{\n  \"email\": \"{{otpEmail}}\",\n  \"password\": \"{{otpPassword}}\",\n  \"name\": \"Postman\",\n  \"last_name\": \"Otp\",\n  \"patronymic\": \"Flow\",\n  \"phone\": \"+998901112233\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Creates a new OTP registration candidate. Fill otp_code manually in the next request."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('otpEmail', `postman-otp-${Date.now()}@example.com`);",
                  "pm.environment.set('otpPassword', '12345678');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.expect(json.message).to.eql('otp_sent');"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify OTP [MANUAL]",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
